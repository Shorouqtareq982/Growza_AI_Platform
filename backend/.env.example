# GROWZA Career Advisor - Environment Variables Template
# Application Settings
PROJECT_NAME=GROWZA Career Advisor
VERSION=1.0.0
DEBUG=false
API_V1_PREFIX=/api/v1

# Security
SECRET_KEY=your-super-secret-key-change-in-production
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# CORS
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/growza_db

# Supabase (optional - alternative to direct PostgreSQL)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Azure Blob Storage (for file uploads)
AZURE_STORAGE_CONNECTION_STRING=
AZURE_CONTAINER_NAME=uploads

# Cloudinary (for image/video processing)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# AI/ML Services
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.0-pro
GEMINI_EMBEDDING_MODEL=models/embedding-001

# External Job APIs
JOB_API_BASE_URL=
JOB_API_KEY=
