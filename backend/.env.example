# ========================
# GROWZA Career Advisor - App Settings
# ========================
PROJECT_NAME=GROWZA Career Advisor
VERSION=1.0.0
DEBUG=false
API_V1_PREFIX=/api/v1

# ========================
# Security
# ========================
SECRET_KEY=your-super-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_DAYS=7
ALGORITHM=HS256

# ========================
# CORS
# ========================
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# ========================
# Database
# ========================
DATABASE_URL=postgresql://user:password@localhost:5432/growza_db

# Optional Supabase (alternative to PostgreSQL)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ========================
# File / Image Storage
# ========================
AZURE_STORAGE_CONNECTION_STRING=
AZURE_CONTAINER_NAME=uploads
AZURE_AUDIO_CONTAINER_NAME=audio

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ========================
# LLM Provider Selection
# ========================
# Set which provider to use primarily: gemini or anthropic
LLM_PROVIDER=gemini

# Gemini Settings
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=models/embedding-001
AssemblyAI_API_KEY=
ElevenLabs_API_KEY=
groq_api_key=
groq_model=Llama 3.3 70B

# Anthropic Settings (commented if not used)
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=your-anthropic-api-key
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ========================
# External Job APIs
# ========================
JOB_API_BASE_URL=https://example-job-api.com
JOB_API_KEY=your-job-api-key

# ========================
# Celery
# ========================
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ========================
# Fallback order (optional)
# ========================
#LLM_PROVIDER_ORDER=gemini,anthropic
